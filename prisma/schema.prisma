generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  accounts        Account[]
  sessions        Session[]
  ownedTeams      Team[]    // teams where user is the owner
  userTeams       UserTeam[] // membership via join table
  userAchievements UserAchievement[]
  userActivities  UserActivity[]
  exports         Export[]
  points          Int       @default(0)
  createdAt       DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  members     UserTeam[]
  tactics     Tactic[]
  seasons     Season[]
}

model UserTeam {
  userId String
  teamId String
  role   String // "owner", "coach", "assistant", "viewer"
  user   User   @relation(fields: [userId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])
  @@unique([userId, teamId])
}

model Tactic {
  id          String   @id @default(cuid())
  name        String
  description String?
  data        String
  teamId      String
  createdBy   String
  visibility  String   @default("PRIVATE")
  team        Team     @relation(fields: [teamId], references: [id])
  exports     Export[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Season {
  id        String   @id @default(cuid())
  name      String   // e.g. "2025 Spring"
  startDate DateTime
  endDate   DateTime
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id])
  matches   Match[]
  createdAt DateTime @default(now())
}

model Match {
  id       String   @id @default(cuid())
  date     DateTime
  opponent String
  location String   // "home", "away", "neutral"
  seasonId String
  season   Season   @relation(fields: [seasonId], references: [id])
  notes    String?
}

model Achievement {
  id           String   @id @default(cuid())
  name         String
  description  String
  icon         String   // emoji or URL
  requirement  String   // JSON: { type: string, threshold?: number, operator?: string }
  points       Int      @default(0)
  userAchievements UserAchievement[]
  createdAt    DateTime @default(now())
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime?
  progress      Int      @default(0)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  @@unique([userId, achievementId])
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime // stored as date (no time)
  actionCount Int    @default(0)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date])
}

model Export {
  id        String   @id @default(cuid())
  userId    String
  tacticId  String
  exportedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  tactic    Tactic   @relation(fields: [tacticId], references: [id])
}
